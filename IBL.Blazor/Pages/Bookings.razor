@page "/bookings"
@inject ApiClient Api

<h1>Booking</h1>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="ibl-card">
            <h4>Ricerca per ID</h4>
            <InputNumber @bind-Value="bookingId" class="form-control" />
            <button class="btn btn-primary mt-3" @onclick="LoadBooking">Cerca booking</button>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="ibl-card">
            <h4>Risultato</h4>
            @if (isLoading)
            {
                <p>Caricamento...</p>
            }
            else if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">@error</div>
            }
            else if (booking is null)
            {
                <p>Nessun booking caricato.</p>
            }
            else
            {
                <dl class="row">
                    <dt class="col-sm-4">Numero</dt><dd class="col-sm-8">@booking.BookingNumber</dd>
                    <dt class="col-sm-4">Porto partenza</dt><dd class="col-sm-8">@booking.OriginPortDisplay</dd>
                    <dt class="col-sm-4">Porto arrivo</dt><dd class="col-sm-8">@booking.DestinationPortDisplay</dd>
                    <dt class="col-sm-4">Origine</dt><dd class="col-sm-8">@booking.OriginAdress</dd>
                    <dt class="col-sm-4">Destinazione</dt><dd class="col-sm-8">@booking.DestinationAdress</dd>
                    <dt class="col-sm-4">Data partenza</dt><dd class="col-sm-8">@booking.ShippingDate.ToString("dd/MM/yyyy")</dd>
                    <dt class="col-sm-4">Data arrivo</dt><dd class="col-sm-8">@booking.EstimatedArrivalDate.ToString("dd/MM/yyyy")</dd>
                    <dt class="col-sm-4">Cliente</dt><dd class="col-sm-8">@booking.CustomerInformations</dd>
                    <dt class="col-sm-4">Consignee</dt><dd class="col-sm-8">@booking.ConsigneeInformations</dd>
                </dl>

                <h5 class="mt-4">Container associati</h5>
                <table class="table table-striped align-middle">
                    <thead>
                        <tr><th>ID</th><th>Numero</th><th>Categoria</th><th>Peso</th><th>Volume</th></tr>
                    </thead>
                    <tbody>
                    @foreach (var item in booking.ContainerSummaries ?? new())
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.ContainerNumber</td>
                            <td>@item.ProductCategoryLabel</td>
                            <td>@item.TotalWeight</td>
                            <td>@item.TotalVolume</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private int bookingId = 1;
    private bool isLoading;
    private string? error;
    private BookingSummaryDto? booking;

    private async Task LoadBooking()
    {
        isLoading = true;
        error = null;
        booking = null;
        try
        {
            booking = await Api.GetBookingByIdAsync(bookingId);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
